# SPW-OPS configuration — copy to .env for local dev (`node --env-file=.env server.js`)
# or set these in Railway → service → Variables. All are optional; with none set,
# the app runs as a plain static server (no database, no Outlook agent).

# ---- Postgres (durable store) ----
# Railway injects DATABASE_URL when you add a Postgres plugin. Prefer the PRIVATE
# URL (no SSL). For an external/public URL, set PGSSLMODE=require (TLS verified).
DATABASE_URL=
# PGSSLMODE=require
# PGSSLROOTCERT=/path/to/railway-ca.pem   # pin the CA when using SSL
# PGSSL_INSECURE=true                      # last resort only — disables TLS verification (MITM risk)

# ---- Payments API auth ----
# Required to expose GET /api/payments. Without it the route is denied (403).
API_TOKEN=

# ---- Outlook → ACH agent (Microsoft Graph) ----
# Set all four to enable the mailbox monitor.
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_MAILBOX=
# Exact sender allowlist (comma-separated) — strongly recommended.
ACH_FROM=vendor.hotline@brinker.com
# Subject substring to match (default "Remit Advice").
ACH_SUBJECT=Remit Advice
# Set to false to skip DMARC verification (default on — keep on).
# ACH_REQUIRE_AUTH_RESULTS=false
# Poll cadence in ms (default 300000, min 60000).
# POLL_INTERVAL_MS=300000
